<?xml version='1.0' standalone='yes'?>
<!DOCTYPE PLUGIN>

<PLUGIN 
  name="auto-unlock"
  author="Derek Kaser"
  version="2026.03.20.0220"
  launch="Settings/AutoUnlock"
  pluginURL="https://raw.githubusercontent.com/dkaser/unraid-auto-unlock/main/plugin/auto-unlock-preview.plg"
  support="https://forums.unraid.net/topic/195584-plugin-automatic-disk-unlock/"
  min="7.2.0"
  
  icon="unlock"
>

<CHANGES>
<![CDATA[

### 2026.03.20.0220

### 🐛 Bug Fixes

- Mark params as nullable ([#70](https://github.com/dkaser/unraid-auto-unlock/pull/70))


### 2026.01.04.1548

### 🚀 Features

- Piece storage in AWS SSM/secrets manager ([#48](https://github.com/dkaser/unraid-auto-unlock/pull/48))

### 🧰 Maintenance

- Add license footer ([#49](https://github.com/dkaser/unraid-auto-unlock/pull/49))

### 2026.01.01.0426

### 🚀 Features

- Add native http handler ([#46](https://github.com/dkaser/unraid-auto-unlock/pull/46))

### 🐛 Bug Fixes

- Don't show instructions with command output ([#45](https://github.com/dkaser/unraid-auto-unlock/pull/45))


For older releases, see https://github.com/dkaser/unraid-auto-unlock/releases
]]>
</CHANGES>

<FILE Name="/boot/config/plugins/auto-unlock/unraid-auto-unlock-2026.03.20.0220-noarch-1.txz">
<URL>https://github.com/dkaser/unraid-auto-unlock/releases/download/2026.03.20.0220/unraid-auto-unlock-2026.03.20.0220-noarch-1.txz</URL>
<SHA256>83440758b413972f96c33e0db0f4716a88d8e91934bbe949aad03eea67b6bda7</SHA256>
</FILE>

<!--
The 'install' script.
-->
<FILE Run="/bin/bash">
<INLINE>
<![CDATA[
upgradepkg --install-new /boot/config/plugins/auto-unlock/unraid-auto-unlock-2026.03.20.0220-noarch-1.txz

# cleanup old versions
rm -f $(ls /boot/config/plugins/auto-unlock/unraid-auto-unlock-*.txz 2>/dev/null | grep -v '2026.03.20.0220')

# remove other branch (if switching between main and preview)
rm -f /boot/config/plugins/auto-unlock.plg
rm -f /var/log/plugins/auto-unlock.plg
# Update plugin name for non-main branches
sed -i "s/Automatic Disk Unlock/Automatic Disk Unlock (Preview)/" /usr/local/emhttp/plugins/auto-unlock/README.md


echo ""
echo "----------------------------------------------------"
echo " auto-unlock has been installed."
echo " Version: 2026.03.20.0220"
echo "----------------------------------------------------"
echo ""
]]>
</INLINE>
</FILE>

<FILE Name="/boot/config/plugins/auto-unlock/.gitignore">
<INLINE>
<![CDATA[
unlock.enc
state.json
config.txt
]]>
</INLINE>
</FILE>

<!--
The 'unlock' script. This only runs if /var/local/emhttp/var.ini does not exist yet.
-->
<FILE Run="/bin/bash">
<INLINE>
<![CDATA[
if [ ! -f /var/local/emhttp/var.ini ]; then
    /usr/local/php/unraid-auto-unlock/bin/autounlock unlock >> /var/log/autounlock.log 2>&1 &
fi

]]>
</INLINE>
</FILE>

<!--
The 'remove' script.
-->
<FILE Run="/bin/bash" Method="remove">
<INLINE>
<![CDATA[
removepkg unraid-auto-unlock

rm -rf /usr/local/emhttp/plugins/auto-unlock
rm -rf /boot/config/plugins/auto-unlock
]]>
</INLINE>
</FILE>

</PLUGIN>
