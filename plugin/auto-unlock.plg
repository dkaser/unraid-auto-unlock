<?xml version='1.0' standalone='yes'?>
<!DOCTYPE PLUGIN>

<PLUGIN 
  name="auto-unlock"
  author="Derek Kaser"
  version="2026.04.18.0247"
  launch="Settings/AutoUnlock"
  pluginURL="https://raw.githubusercontent.com/dkaser/unraid-auto-unlock/main/plugin/auto-unlock.plg"
  support="https://forums.unraid.net/topic/195584-plugin-automatic-disk-unlock/"
  min="7.2.0"
  
  icon="unlock"
>

<CHANGES>
<![CDATA[

### 2026.04.18.0247

### 🐛 Bug Fixes

- Make sure keyfile is cleaned up if process is killed ([#73](https://github.com/dkaser/unraid-auto-unlock/pull/73))

### 🧰 Maintenance

- Update dependency symfony/process to v7.4.5 [security] ([#67](https://github.com/dkaser/unraid-auto-unlock/pull/67))

### 2026.03.29.0308

### 🐛 Bug Fixes

- Keyfile test fails when all encrypted disks are in the array ([#72](https://github.com/dkaser/unraid-auto-unlock/pull/72)) 

### 2026.03.27.0427

### 🐛 Bug Fixes

- Keyfile test fails when all encrypted disks are in the array ([#72](https://github.com/dkaser/unraid-auto-unlock/pull/72)) 
 


For older releases, see https://github.com/dkaser/unraid-auto-unlock/releases
]]>
</CHANGES>

<FILE Name="/boot/config/plugins/auto-unlock/unraid-auto-unlock-2026.04.18.0247-noarch-1.txz">
<URL>https://github.com/dkaser/unraid-auto-unlock/releases/download/2026.04.18.0247/unraid-auto-unlock-2026.04.18.0247-noarch-1.txz</URL>
<SHA256>256b230bdc7403240c818d16126329c1e2c51a2ebbce7da1c893b0ff109803fe</SHA256>
</FILE>

<!--
The 'install' script.
-->
<FILE Run="/bin/bash">
<INLINE>
<![CDATA[
upgradepkg --install-new /boot/config/plugins/auto-unlock/unraid-auto-unlock-2026.04.18.0247-noarch-1.txz

# cleanup old versions
rm -f $(ls /boot/config/plugins/auto-unlock/unraid-auto-unlock-*.txz 2>/dev/null | grep -v '2026.04.18.0247')

# remove other branch (if switching between main and preview)

rm -f /boot/config/plugins/auto-unlock-preview.plg
rm -f /var/log/plugins/auto-unlock-preview.plg


echo ""
echo "----------------------------------------------------"
echo " auto-unlock has been installed."
echo " Version: 2026.04.18.0247"
echo "----------------------------------------------------"
echo ""
]]>
</INLINE>
</FILE>

<FILE Name="/boot/config/plugins/auto-unlock/.gitignore">
<INLINE>
<![CDATA[
unlock.enc
state.json
config.txt
]]>
</INLINE>
</FILE>

<!--
The 'unlock' script. This only runs if /var/local/emhttp/var.ini does not exist yet.
-->
<FILE Run="/bin/bash">
<INLINE>
<![CDATA[
if [ ! -f /var/local/emhttp/var.ini ]; then
    /usr/local/php/unraid-auto-unlock/bin/autounlock unlock >> /var/log/autounlock.log 2>&1 &
fi

]]>
</INLINE>
</FILE>

<!--
The 'remove' script.
-->
<FILE Run="/bin/bash" Method="remove">
<INLINE>
<![CDATA[
removepkg unraid-auto-unlock

rm -rf /usr/local/emhttp/plugins/auto-unlock
rm -rf /boot/config/plugins/auto-unlock
]]>
</INLINE>
</FILE>

</PLUGIN>
